# Copy to `.env` for docker-compose. Compose reads these; the app container
# gets ADMIN_DB_* from compose itself (see docker-compose.yml).

# Admin/backing MySQL — DB_PASSWORD is the app user's password (querygate user).
MYSQL_ROOT_PASSWORD=change-me-strong-root-password
DB_PASSWORD=change-me-strong-app-password

# Security — generate real secrets, do not ship these.
#   JWT_SECRET:     openssl rand -base64 48
#   ENCRYPTION_KEY: openssl rand -base64 32   (>=32 chars, encrypts stored DB creds)
JWT_SECRET=change-me-to-random-64-char-string
ENCRYPTION_KEY=change-me-to-a-random-secret-at-least-32-chars

# CORS: browser origins allowed to call the API. Include your admin dashboard
# origin. If serving the SPA on the same host:port, the default is fine.
ALLOWED_ORIGINS=http://localhost:3000
