# Admin Database
ADMIN_DB_HOST=localhost
ADMIN_DB_PORT=3306
ADMIN_DB_NAME=querygate_admin
ADMIN_DB_USER=root
ADMIN_DB_PASSWORD=

# Security
JWT_SECRET=change-me-to-random-64-char-string
# Any random secret string, >=32 chars. Generate: openssl rand -base64 32
ENCRYPTION_KEY=change-me-to-a-random-secret-at-least-32-chars

# Server
PORT=3000
NODE_ENV=development

# Comma-separated browser origins allowed to call the API (CORS).
# In production set this to your admin dashboard origin(s); do NOT leave it open.
ALLOWED_ORIGINS=http://localhost:5173
